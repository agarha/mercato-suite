{
  "slug": "mercato-payouts",
  "namespace": "Mercato\\Payouts",
  "version": "0.1.0",
  "sdk_version": "^0.1",
  "requires": [
    "mercato-core@^0.1",
    "mercato-commissions@^0.1",
    "mercato-stripe-connect@^0.1"
  ],
  "provides_events": [
    "mercato.payout.scheduled.v1",
    "mercato.payout.succeeded.v1",
    "mercato.payout.failed.v1",
    "mercato.payout.reconciled.v1"
  ],
  "consumes_events": [
    "mercato.commission.recorded.v1"
  ],
  "capabilities": [
    "mercato_payouts_read_own",
    "mercato_payouts_admin"
  ],
  "tables": [
    "wp_mercato_payouts",
    "wp_mercato_payout_batches",
    "wp_mercato_payout_items",
    "wp_mercato_reconciliation_runs"
  ],
  "tier": "domain",
  "feature_flag": "mercato.payouts"
}
