{
  "name": "mercato/mercato-suite",
  "description": "Mercato marketplace platform implementation monorepo.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "phpstan/phpstan": "^1.11"
  },
  "autoload": {
    "psr-4": {
      "Mercato\\": "apps/wordpress/wp-content/plugins/mercato-suite/modules/"
    }
  },
  "scripts": {
    "analyse": "phpstan analyse apps/wordpress/wp-content/plugins/mercato-suite/modules --level=6",
    "test": "phpunit"
  }
}
