{
  "slug": "mercato-notifications",
  "namespace": "Mercato\\Notifications",
  "version": "0.1.0",
  "sdk_version": "^0.1",
  "requires": [
    "mercato-core@^0.1",
    "mercato-sendgrid@^0.1"
  ],
  "provides_events": [
    "mercato.notification.requested.v1",
    "mercato.notification.delivered.v1",
    "mercato.notification.failed.v1"
  ],
  "consumes_events": [
    "mercato.order.suborder.created.v1",
    "mercato.order.status.changed.v1",
    "mercato.payout.succeeded.v1",
    "mercato.payout.failed.v1",
    "mercato.vendor.activated.v1",
    "mercato.refund.created.v1",
    "mercato.message.posted.v1"
  ],
  "capabilities": [
    "mercato_notifications_admin"
  ],
  "tables": [
    "wp_mercato_notification_templates",
    "wp_mercato_notification_log",
    "wp_mercato_webhooks",
    "wp_mercato_webhook_deliveries"
  ],
  "tier": "domain",
  "feature_flag": "mercato.notifications"
}
